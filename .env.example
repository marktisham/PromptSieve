GCP_PROJECT=your-gcp-project-id
GCP_LOCATION=us-central1
MODEL_NAME=gemini-2.5-flash

# SQLite database path (relative to project root)
DB_PATH=demo_database.db

# Model Armor — leave empty to run without it (graceful degradation)
# Fill in after provisioning a template in your GCP project
MODEL_ARMOR_TEMPLATE_ID=

# Auth: run `gcloud auth application-default login` — no service account key needed
